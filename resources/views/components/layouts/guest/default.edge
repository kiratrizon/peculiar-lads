	<style>
		@keyframes float {
			0%, 100% { transform: translateY(0px); }
			50% { transform: translateY(-20px); }
		}
		.float-animation {
			animation: float 6s ease-in-out infinite;
		}
		@keyframes pulse-glow {
			0%, 100% { box-shadow: 0 0 20px rgba(250, 204, 21, 0.5); }
			50% { box-shadow: 0 0 40px rgba(250, 204, 21, 0.8); }
		}
		.pulse-glow {
			animation: pulse-glow 2s ease-in-out infinite;
		}
	</style>
</head>
<body class="bg-gradient-to-br from-indigo-950 via-purple-950 to-violet-950 min-h-screen flex flex-col relative overflow-x-hidden">
