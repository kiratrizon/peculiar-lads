<!DOCTYPE html>

<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{{ env('GUILD_NAME') }} | {{ $title }}</title>
	@vite('resources/ts/app.ts')
	{{{ $slots.styles ? await $slots.styles() : '' }}}

<style>
	@keyframes float {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-15px); }
	}
	.float-animation {
		animation: float 6s ease-in-out infinite;
	}
</style>

</head>

<body class="bg-gradient-to-br from-indigo-950 via-purple-950 to-violet-950 min-h-screen flex text-indigo-100">

<!-- Sidebar -->
<aside class="w-64 bg-black/50 backdrop-blur-md border-r border-yellow-500/30 flex flex-col">

	<div class="p-6 border-b border-yellow-500/30 flex items-center gap-2">
		<span class="text-2xl">🐉</span>
		<span class="text-lg font-bold text-yellow-300">
			{{ env('GUILD_NAME') }}
		</span>
	</div>

	<nav class="flex-1 p-4 space-y-2">

		@let(routePrefix = $entity === "Admin" ? "admin" : ($entity === "User" ? "user" : ""))

		<!-- selected and disabled -->
		<a href="{{ route(`${routePrefix}.index`) }}"
		   class="block px-4 py-2 rounded-lg hover:bg-yellow-500/10 hover:text-yellow-300 transition {{ $selected === 'home' ? 'bg-yellow-500/10 text-yellow-300 cursor-not-allowed' : '' }}">
			🏠 Dashboard
		</a>

		<a href="{{ route(`${routePrefix}.members`) }}"
		   class="block px-4 py-2 rounded-lg hover:bg-yellow-500/10 hover:text-yellow-300 transition {{ $selected === 'members' ? 'bg-yellow-500/10 text-yellow-300 cursor-not-allowed' : '' }}">
			👥 Guild Members
		</a>

		<a href="{{ route(`${routePrefix}.events`) }}"
		   class="block px-4 py-2 rounded-lg hover:bg-yellow-500/10 hover:text-yellow-300 transition {{ $selected === 'events' ? 'bg-yellow-500/10 text-yellow-300 cursor-not-allowed' : '' }}">
			📅 Events
		</a>

		@if($entity === "Admin")
		<a href="{{ route(`${routePrefix}.recruits`) }}"
		   class="block px-4 py-2 rounded-lg hover:bg-yellow-500/10 hover:text-yellow-300 transition {{ $selected === 'recruits' ? 'bg-yellow-500/10 text-yellow-300 cursor-not-allowed' : '' }}">
			📝 Recruits
		</a>
		@end

		<a href="{{ route(`${routePrefix}.settings`) }}"
		   class="block px-4 py-2 rounded-lg hover:bg-yellow-500/10 hover:text-yellow-300 transition {{ $selected === 'settings' ? 'bg-yellow-500/10 text-yellow-300 cursor-not-allowed' : '' }}">
			⚙️ Settings
		</a>

	</nav>

	<div class="p-4 border-t border-yellow-500/30 text-xs text-indigo-400 text-center">
		Dragon Nest SEA Guild
	</div>

</aside>

<!-- Main area -->
<div class="flex-1 flex flex-col">

	<!-- Topbar -->
	<header class="bg-black/40 backdrop-blur-md border-b border-yellow-500/30 px-6 py-4 flex justify-between items-center">

		<div class="font-semibold text-yellow-300 text-lg">
			Guild Dashboard
		</div>

		<div class="flex items-center gap-4">

			<div class="text-sm text-indigo-300">
				Hello, {{ request().user()?.name ?? 'Adventurer' }}!
			</div>

			<form method="get" action="{{ route(`${routePrefix}.logout`) }}">
				<button
					class="px-3 py-1 rounded bg-red-600/80 hover:bg-red-500 text-white text-sm transition hover:cursor-pointer">
					Logout
				</button>
			</form>

		</div>

	</header>

	<!-- Page Content -->
	<main class="flex-1 p-6 relative z-10">

		<!-- Optional animated background -->
		<div class="fixed inset-0 pointer-events-none opacity-10">
			<div class="absolute top-20 left-20 w-40 h-40 bg-yellow-400 rounded-full blur-3xl float-animation"></div>
			<div class="absolute bottom-20 right-20 w-40 h-40 bg-purple-500 rounded-full blur-3xl float-animation"
				 style="animation-delay: 2s;"></div>
		</div>

		{{{ await $slots.main() }}}

	</main>

</div>

</body>
</html>
