<!DOCTYPE html>
<html lang="{{ request().getLanguage() }}">
<head>
	<meta charset="UTF-8">
	<!-- Sets the theme before anything else paints, so the page never flashes
	     the default theme before swapping to the saved one (see app.ts). -->
	<script>
	(function () {
		var theme = localStorage.getItem("pecu:theme");
		var valid = ["dark-abyss", "lightning-blaze", "icy-moon", "heatwave"];
		document.documentElement.setAttribute("data-theme", valid.indexOf(theme) !== -1 ? theme : "dark-abyss");
	})();
	</script>
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<!-- seo -->
	<meta name="description" content="{{ env('GUILD_NAME') }} is a Dragon Nest SEA guild for unique adventurers and friends. Join our Philippines-based community!">
	<meta name="keywords" content="Dragon Nest SEA, Guild, Community, Philippines">
	<meta name="author" content="Kiratrizon">
	<title>{{ env('GUILD_NAME') }} Guild | Dragon Nest SEA</title>
	@icon('assets/peculiarlads-icon-dark.png')
	@vite('resources/ts/app.ts')
	<meta name="description" content="{{ env('GUILD_NAME') }} is a Dragon Nest SEA guild for unique adventurers and friends. Join our Philippines-based community!">
	<!-- csrf -->
    {{{ csrfMeta() }}}
	    <meta name="language" content="{{ request().route('lang') ? "on" : "off" }}">
	@vite('resources/css/dark.css')
	@vite('resources/css/guest.css')
	@vite('resources/ts/shared/lang-select.ts')
</head>
<body class="guest-shell min-h-screen flex flex-col relative overflow-x-hidden">
	<!-- Animated background elements -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none opacity-20">
		<div class="absolute top-20 left-10 w-32 h-32 bg-gray-400 rounded-full blur-3xl float-animation"></div>
		<div class="absolute top-40 right-20 w-48 h-48 bg-gray-600 rounded-full blur-3xl float-animation" style="animation-delay: 2s;"></div>
		<div class="absolute bottom-20 left-1/3 w-40 h-40 bg-gray-500 rounded-full blur-3xl float-animation" style="animation-delay: 4s;"></div>
	</div>

	<!-- Navigation -->
	<nav class="guest-nav relative z-20 backdrop-blur-md border-b">
		<div class="container mx-auto px-4 py-4 flex justify-between items-center">
			<div class="flex items-center gap-2">
				<img class="theme-icon h-6 w-6" src="/assets/peculiarlads-icon-dark.png" alt="{{ env('GUILD_NAME') }}" />
				<span class="guest-brand text-xl font-bold">{{ env('GUILD_NAME') }}</span>
			</div>

			<button id="guestNavToggle" type="button" class="guest-link md:hidden inline-flex items-center justify-center rounded-md border px-2.5 py-1.5 transition" style="border-color: var(--border);" aria-label="{{ request().__('menu') }}" aria-expanded="false" aria-controls="guestNavMenu">
				☰
			</button>

			<div id="guestNavMenu" class="hidden md:flex flex-col md:flex-row gap-3 md:items-center absolute md:static top-full inset-x-0 md:inset-auto px-4 py-4 md:p-0 border-b md:border-0" style="background: var(--panel); border-color: var(--border);">
				<a href="{{ route('welcome') }}#about" class="guest-link px-2 py-1 rounded transition">{{ request().__('about') }}</a>
				<a href="{{ route('welcome') }}#features" class="guest-link px-2 py-1 rounded transition">{{ request().__('features') }}</a>
				<a href="{{ route('welcome') }}#classes" class="guest-link px-2 py-1 rounded transition">{{ request().__('classes') }}</a>
				<a href="{{ route('welcome') }}#join" class="guest-link px-2 py-1 rounded transition">{{ request().__('join_us') }}</a>
				<!-- login button -->
				@if(!removeLoginButton)
					<a href="{{ route('login') }}" class="guest-link px-2 py-1 rounded transition">{{ request().__('login') }}</a>
				@end
				<select id="langSelect" class="lang-select" aria-label="{{ request().__('language') }}">
					@each((val, key) in $languageConversion)
						<option value="{{ key }}" {{ request().getLanguage() === key ? 'selected' : '' }}>{{ val }}</option>
					@end
				</select>
				<select id="themeSelectGuestDefault" class="theme-select" aria-label="{{ request().__('theme') }}">
					<option value="dark-abyss">{{ request().__('theme_dark_abyss') }}</option>
					<option value="lightning-blaze">{{ request().__('theme_lightning_blaze') }}</option>
					<option value="icy-moon">{{ request().__('theme_icy_moon') }}</option>
					<option value="heatwave">{{ request().__('theme_heatwave') }}</option>
				</select>
			</div>
		</div>
	</nav>

    {{{ await $slots.main() }}}

	<script>
		(() => {
			const toggle = document.getElementById("guestNavToggle");
			const menu = document.getElementById("guestNavMenu");
			toggle?.addEventListener("click", () => {
				const isOpen = !menu.classList.contains("hidden");
				menu.classList.toggle("hidden", isOpen);
				toggle.setAttribute("aria-expanded", String(!isOpen));
			});
		})();
	</script>

	<footer class="guest-footer relative z-10 py-8 backdrop-blur-md border-t">
		<div class="container mx-auto px-4">
			<div class="text-center mb-6">
				<h3 class="guest-title text-2xl font-bold mb-2">{{ env('GUILD_NAME') }}</h3>
				<p class="guest-soft">{{ request().__('where_legends') }}</p>
			</div>
			<div class="flex justify-center gap-6 mb-6 text-3xl">
				<a href="#" class="guest-link guest-soft transition" title="Discord">💬</a>
				<a href="#" class="guest-link guest-soft transition" title="Facebook">📘</a>
				<a href="#" class="guest-link guest-soft transition" title="YouTube">📺</a>
			</div>
			<div class="text-center guest-copy space-y-2">
				<p>&copy; 2026 {{ env('GUILD_NAME') }} Guild — Dragon Nest SEA</p>
				<p class="text-sm guest-soft">{{ request().__('not_affiliated') }}</p>
				<p class="text-xs guest-muted">{{ request().__('made_with_love') }}</p>
			</div>
		</div>
	</footer>
</body>
</html>
