<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blocklisted | {{ $title }}</title>

    @vite('resources/ts/app.ts')
    {{{ $slots.styles ? await $slots.styles() : '' }}}
</head>

<body class="bg-gradient-to-br from-indigo-950 via-purple-950 to-violet-950 min-h-screen text-indigo-100">

<!-- Topbar -->
<header class="bg-black/40 backdrop-blur-md border-b border-yellow-500/30 px-6 py-4 flex justify-between items-center">

    <div class="font-semibold text-yellow-300 text-lg flex items-center gap-2">
        🚫 Blocklisted Panel
    </div>

    <nav class="flex items-center gap-4 text-sm">
        <a href="/admin"
           class="px-3 py-1 rounded hover:bg-yellow-500/10 hover:text-yellow-300 transition">
            Dashboard
        </a>

        <a href="/blocklisted/players"
           class="px-3 py-1 rounded hover:bg-yellow-500/10 hover:text-yellow-300 transition">
            Players
        </a>
    </nav>

</header>

<!-- Page Content -->
<main class="max-w-6xl mx-auto p-6 flex flex-col gap-6 relative z-10">

    <!-- Floating background accents -->
    <div class="fixed inset-0 pointer-events-none opacity-10">
        <div class="absolute top-20 left-20 w-40 h-40 bg-yellow-400 rounded-full blur-3xl"></div>
        <div class="absolute bottom-20 right-20 w-40 h-40 bg-purple-500 rounded-full blur-3xl"></div>
    </div>

    <!-- Page Header -->
    <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-bold text-yellow-300">
            {{ $title }}
        </h1>
        <p class="text-sm text-indigo-300">
            Manage and review all blocked players in the system.
        </p>
    </div>

    <!-- Content Card Wrapper -->
    <div class="bg-black/40 backdrop-blur-md border border-yellow-500/20 rounded-xl p-6 shadow-lg flex flex-col gap-6">
        {{{ await $slots.main() }}}
    </div>

</main>

<!-- Footer -->
<footer class="text-center text-xs text-indigo-400 py-4 border-t border-yellow-500/20 bg-black/30 backdrop-blur-md">
    © {{ new Date().getFullYear() }} Blocklisted System
</footer>

</body>
</html>